# nanopb field options: bound every dynamic field so each message is a
# fixed-size, zero-heap C struct (safe for the radio task, no malloc).
# String max_size includes the null terminator nanopb appends.
meshtastic.Data.payload        max_size:237
meshtastic.User.id             max_size:16
meshtastic.User.long_name      max_size:48
meshtastic.User.short_name     max_size:16
meshtastic.User.macaddr        max_size:6  fixed_length:true
